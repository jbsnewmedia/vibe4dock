{
  "categories": [
    {
      "unique_key": "ai-cli",
      "id": "ai-cli",
      "label": "AI CLI",
      "order": 100
    },
    {
      "unique_key": "system",
      "id": "system",
      "label": "System & Runtime",
      "order": 200
    },
    {
      "unique_key": "php-frameworks",
      "id": "php-frameworks",
      "label": "PHP & Frameworks",
      "order": 300
    }
  ],
  "tools": [
    {
      "id": "symfony-cli",
      "category": "php-frameworks",
      "label": "Symfony CLI",
      "description": "The official Symfony CLI to help you build, run, and manage your Symfony applications.",
      "usage": "",
      "check": "symfony -V 2>/dev/null | grep -oP '\\d+\\.\\d+\\.\\d+' | head -n1 | grep .",
      "install": "curl -sS https://get.symfony.com/cli/installer | bash -s -- --install-dir=/usr/local/bin",
      "uninstall": "rm /usr/local/bin/symfony"
    },
    {
      "id": "node",
      "category": "system",
      "label": "Node.js",
      "type": "versioned",
      "default_version": "node-22",
      "mounts": [
        "./docker/web/settings/npm:/home/application/.npm"
      ],
      "description": "JavaScript runtime built on Chrome's V8 JavaScript engine.",
      "usage": "",
      "versions": [
        {
          "id": "node-18",
          "label": "18 LTS",
          "check": "node -v 2>/dev/null | grep v18 | sed 's/v//' | grep .",
          "install": "curl -fsSL https://deb.nodesource.com/setup_18.x | bash - && apt-get install -y nodejs",
          "uninstall": "apt-get remove -y nodejs"
        },
        {
          "id": "node-19",
          "label": "19",
          "check": "node -v 2>/dev/null | grep v19 | sed 's/v//' | grep .",
          "install": "curl -fsSL https://deb.nodesource.com/setup_19.x | bash - && apt-get install -y nodejs",
          "uninstall": "apt-get remove -y nodejs"
        },
        {
          "id": "node-20",
          "label": "20 LTS",
          "check": "node -v 2>/dev/null | grep v20 | sed 's/v//' | grep .",
          "install": "curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && apt-get install -y nodejs",
          "uninstall": "apt-get remove -y nodejs"
        },
        {
          "id": "node-21",
          "label": "21",
          "check": "node -v 2>/dev/null | grep v21 | sed 's/v//' | grep .",
          "install": "curl -fsSL https://deb.nodesource.com/setup_21.x | bash - && apt-get install -y nodejs",
          "uninstall": "apt-get remove -y nodejs"
        },
        {
          "id": "node-22",
          "label": "22 LTS",
          "check": "node -v 2>/dev/null | grep v22 | sed 's/v//' | grep .",
          "install": "curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && apt-get install -y nodejs",
          "uninstall": "apt-get remove -y nodejs"
        },
        {
          "id": "node-23",
          "label": "23 (Current)",
          "check": "node -v 2>/dev/null | grep v23 | sed 's/v//' | grep .",
          "install": "curl -fsSL https://deb.nodesource.com/setup_23.x | bash - && apt-get install -y nodejs",
          "uninstall": "apt-get remove -y nodejs"
        }
      ]
    },
    {
      "id": "yarn",
      "category": "system",
      "label": "Yarn",
      "type": "versioned",
      "default_version": "yarn-3",
      "description": "Install the project dependencies.",
      "usage": "",
      "dependencies": [
        "node"
      ],
      "versions": [
        {
          "id": "yarn-1",
          "label": "1.22 (Classic)",
          "check": "yarn -v 2>/dev/null | grep ^1\\. | grep .",
          "install": "corepack enable && corepack prepare yarn@1.22.22 --activate",
          "uninstall": "corepack disable yarn"
        },
        {
          "id": "yarn-3",
          "label": "3",
          "check": "yarn -v 2>/dev/null | grep ^3\\. | grep .",
          "install": "corepack enable && corepack prepare yarn@3.6.4 --activate",
          "uninstall": "corepack disable yarn"
        }
      ]
    },
    {
      "id": "pnpm",
      "category": "system",
      "label": "pnpm",
      "type": "versioned",
      "default_version": "pnpm-10",
      "description": "Fast, disk space efficient package manager.",
      "usage": "",
      "dependencies": [
        "node"
      ],
      "versions": [
        {
          "id": "pnpm-9",
          "label": "9",
          "check": "pnpm -v 2>/dev/null | grep ^9\\. | grep .",
          "install": "corepack enable && corepack prepare pnpm@9.15.4 --activate",
          "uninstall": "corepack disable pnpm"
        },
        {
          "id": "pnpm-10",
          "label": "10",
          "check": "pnpm -v 2>/dev/null | grep ^10\\. | grep .",
          "install": "corepack enable && corepack prepare pnpm@10.4.1 --activate",
          "uninstall": "corepack disable pnpm"
        }
      ]
    },
    {
      "id": "copilot",
      "category": "ai-cli",
      "label": "GitHub Copilot CLI",
      "mounts": [
        "./docker/web/settings/copilot:/home/application/.copilot"
      ],
      "description": "Your AI pair programmer in the terminal.",
      "usage": "",
      "dependencies": [
        "node"
      ],
      "check": "npm list -g @github/copilot --depth=0 --loglevel=silent 2>/dev/null | grep @github/copilot | cut -d@ -f3 | grep .",
      "install": "npm install -g @github/copilot@latest --prefix=/usr",
      "uninstall": "npm uninstall -g @github/copilot --prefix=/usr || true"
    },
    {
      "id": "codex",
      "category": "ai-cli",
      "label": "Codex CLI",
      "mounts": [
        "./docker/web/settings/codex:/home/application/.codex"
      ],
      "description": "OpenAI's local coding agent for the terminal.",
      "usage": "",
      "dependencies": [
        "node"
      ],
      "check": "codex --version 2>/dev/null | grep .",
      "install": "npm install -g @openai/codex@latest --prefix=/usr",
      "uninstall": "npm uninstall -g @openai/codex --prefix=/usr || true"
    },
    {
      "id": "claude",
      "category": "ai-cli",
      "label": "Claude Code",
      "mounts": [
        "./docker/web/settings/claude:/home/application/.claude"
      ],
      "description": "Claude Code is a command-line interface that brings Claude's coding expertise directly to your terminal.",
      "usage": "",
      "dependencies": [
        "node"
      ],
      "check": "claude --version 2>/dev/null | cut -d' ' -f1 | grep .",
      "install": "npm install -g @anthropic-ai/claude-code --prefix=/usr",
      "uninstall": "npm uninstall -g @anthropic-ai/claude-code --prefix=/usr || true"
    },
    {
      "id": "cline",
      "category": "ai-cli",
      "label": "Cline CLI",
      "mounts": [
        "./docker/web/settings/cline:/home/application/.cline"
      ],
      "description": "Autonomous AI coding agent in your terminal.",
      "usage": "",
      "dependencies": [
        "node"
      ],
      "check": "cline --version 2>/dev/null | grep .",
      "install": "npm install -g cline@latest --prefix=/usr",
      "uninstall": "npm uninstall -g cline --prefix=/usr || true"
    },
    {
      "id": "hermes",
      "category": "ai-cli",
      "label": "Hermes CLI",
      "mounts": [
        "./docker/web/settings/hermes:/home/application/.hermes"
      ],
      "description": "Nous Research's self-improving coding and automation agent.",
      "usage": "",
      "check": "hermes --version 2>/dev/null | grep .",
      "install": "sudo -u application env HOME=/home/application bash -lc 'curl -fsSL https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.sh | bash -s -- --skip-setup --skip-browser' && ln -sf /home/application/.local/bin/hermes /usr/local/bin/hermes",
      "uninstall": "rm -f /usr/local/bin/hermes && sudo -u application env HOME=/home/application bash -lc 'rm -f ~/.local/bin/hermes && rm -rf ~/.hermes' || true"
    },
    {
      "id": "junie",
      "category": "ai-cli",
      "label": "Junie CLI",
      "mounts": [
        "./docker/web/settings/junie:/home/application/.junie"
      ],
      "description": "JetBrains' agentic coding tool for the terminal.",
      "usage": "",
      "dependencies": [
        "node"
      ],
      "check": "junie --version 2>/dev/null | grep .",
      "install": "npm install -g @jetbrains/junie@latest --prefix=/usr",
      "uninstall": "npm uninstall -g @jetbrains/junie --prefix=/usr || true"
    }
  ]
}
